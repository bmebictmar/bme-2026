# Quarto build output
/_site/
_site_libs/
/.quarto/
.quarto-cache/

# Quarto freeze cache
/_freeze/

# Python
.venv/
__pycache__/
.ipynb_checkpoints/

# R — renv (ignorar tudo exceto arquivos necessários para CI)
renv/*
!renv/activate.R
!renv/settings.json
!renv/.gitignore

# R session files
.Rproj.user/
.Rhistory
.RData
.Ruserdata

# Cache e arquivos temporários
*.log
*.tmp
*.bak
render.log
render.out

# Arquivos de sistema
.DS_Store
Thumbs.db

# Editor
.vscode/
*.swp
*.swo

# Node/V8
.local-v8/

# Claude Code
.claude/

# Conteúdo não versionado
/content/exams/
